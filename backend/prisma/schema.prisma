datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// role values: "ADMIN" | "INSTRUCTOR" | "STUDENT"

model User {
  id             String         @id @default(uuid())
  username       String         @unique
  email          String         @unique
  firstName      String
  lastName       String
  mobile         String
  password       String?
  role           String         @default("STUDENT")  // ADMIN | INSTRUCTOR | STUDENT
  dob            DateTime?
  image          String?
  token          String?
  bookmarks      String[]       @default([])
  isVerified     Boolean?       @default(false)
  isAdmin        Boolean?       @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tokens         Token[]
  subscriptions  Subscription[]
  reviews        Review[]
  authorProfile  Author?        // if INSTRUCTOR, links to their Author record
}

model Token {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token          String
  expireAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Subscription {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId       String
  watchedVideoId String[] @default([])
}

model Course {
  id             String        @id @default(uuid())
  name           String        @unique
  description    String
  fee            Float
  authorId       String
  author         Author        @relation(fields: [authorId], references: [id])
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  image          String?
  language       String?
  subscriptions  Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  courseTokens   CourseToken[]
  addons         Addon[]
  lessons        Lesson[]
  reviews        Review[]
}

model CourseToken {
  id             String   @id @default(uuid())
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tokenId        Int
  token          String
  userId         String?
}

model Lesson {
  id             String   @id @default(uuid())
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  url            String
}

model Addon {
  id             String   @id @default(uuid())
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  date           String?
  contents       Json[]
}

model Review {
  id             String   @id @default(uuid())
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating         Int
  comment        String?
  time           String?
}

model Author {
  id             String   @id @default(uuid())
  name           String
  profession     String
  email          String?
  mobile         String?
  image          String?
  userId         String?  @unique   // linked User account (INSTRUCTOR role)
  user           User?    @relation(fields: [userId], references: [id])
  courses        Course[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Category {
  id             String   @id @default(uuid())
  name           String   @unique
  icon           String
  courses        Course[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  message   String
  meta      String?
  timestamp DateTime @default(now())
}
