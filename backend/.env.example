# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# Server
PORT=3001
BACKEND_URL="http://localhost:3001"

# JWT Secrets — generate strong random strings for production
# e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET="replace_with_strong_random_secret"
REFRESH_TOKEN_SECRET="replace_with_strong_random_secret"

# SendGrid Email API
SENDGRID_API_KEY="test"

# Auth
REQUIRES_AUTH=true

# CORS — frontend origin allowed to call the API
FRONTEND_URL="http://localhost:3000"
